<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<section class="contact-page" data-scroll-section>
  <div class="contact-container">
    <div class="contact-page-form2" data-scroll>
      <div class="contact-page-form2-top">
        <h2>{{ section.settings.heading1 }}</h2>
        <p>{{ section.settings.body1 }}</p>
      </div>
      <div class="contact-page-form2-form active">
        {% form 'contact', id: 'contactID2' %}
          {% if form.posted_successfully? %}
            <script>
              window.location = "/pages/thank-you";
            </script>
          {% else %}
            {{ form.errors | default_errors }}
          {% endif %}
          <div class="contact-form-top flex align">
            <div class="contact-form-top-left flex flex-c">
              <label for="name1">Full Name*</label>
              <input
                id="name1"
                type="text"
                name="contact[name]"
              >
              <span class="field-error" id="name1-error">Please enter your full name.</span>
            </div>
            <div class="contact-form-top-right flex flex-c">
              <label for="email1">Email Address*</label>
              <input
                type="text"
                id="email1"
                name="contact[email]"
              >
              <span class="field-error" id="email1-error">Please enter a valid email address.</span>
            </div>
          </div>
          <div class="contact-form-bottom flex flex-c">
            <label for="date">Preferred Date*</label>
            <input
              type="date"
              id="date"
              name="contact[date]"
            >
            <span class="field-error" id="date-error">Please select a preferred date.</span>
          </div>
          <div class="contact-form-bottom flex flex-c">
            <label for="subject">Select Jewellery Type*</label>
            <div class="custom-select">
              <select
                name="contact[subject]"
                id="subject"
              >
                <option value="Select One">Select One</option>
                <option value="Ring">Ring</option>
                <option value="Necklace">Necklace</option>
                <option value="Bracelet">Bracelet</option>
              </select>
            </div>
            <span class="field-error" id="subject-error">Please select a jewellery type.</span>
          </div>
          <div class="contact-form-bottom flex flex-c">
            <label for="phone">Phone Number (Optional)</label>
            <input
              type="tel"
              id="phone"
              placeholder="0000-000-000"
              minlength="0"
              maxlength="10"
              name="contact[phone]"
            >
          </div>
          <div class="contact-form-bottom flex flex-c">
            <label for="body1">Message*</label>
            <textarea
              id="body1"
              name="contact[body]"
            ></textarea>
            <span class="field-error" id="body1-error">Please enter your message.</span>
          </div>
          <div class="contact-form-btn">
            <input type="submit" id="contactSubmitBtn" value="Submit">
          </div>
        {% endform %}
      </div>
    </div>
  </div>
</section>

<style>
  .contact-page {
    padding-top: 150px;
  }

  /* Validation error styles */
  .field-error {
    display: none;
    color: #e53e3e;
    font-size: 13px;
    margin-top: 4px;
  }

  .field-error.visible {
    display: block;
  }

  input.input-error,
  textarea.input-error,
  select.input-error {
    border-color: #e53e3e !important;
    outline-color: #e53e3e !important;
  }
</style>

<script>
  document.getElementById('contactSubmitBtn').addEventListener('click', function (e) {
    e.preventDefault();

    var isValid = true;

    // Helper: show error
    function showError(inputId, errorId) {
      var input = document.getElementById(inputId);
      var error = document.getElementById(errorId);
      if (error) {
        error.classList.add('visible');
      }
      if (input) {
        input.classList.add('input-error');
      }
    }

    // Helper: clear error
    function clearError(inputId, errorId) {
      var input = document.getElementById(inputId);
      var error = document.getElementById(errorId);
      if (error) {
        error.classList.remove('visible');
      }
      if (input) {
        input.classList.remove('input-error');
      }
    }

    // Full Name
    var name = document.getElementById('name1');
    if (!name || name.value.trim() === '') {
      showError('name1', 'name1-error');
      isValid = false;
    } else {
      clearError('name1', 'name1-error');
    }

    // Email — basic format check
    var email = document.getElementById('email1');
    var emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!email || email.value.trim() === '' || !emailPattern.test(email.value.trim())) {
      showError('email1', 'email1-error');
      isValid = false;
    } else {
      clearError('email1', 'email1-error');
    }

    // Date
    var date = document.getElementById('date');
    if (!date || date.value.trim() === '') {
      showError('date', 'date-error');
      isValid = false;
    } else {
      clearError('date', 'date-error');
    }

    // Jewellery Type
    var subject = document.getElementById('subject');
    if (!subject || subject.value === 'Select One' || subject.value.trim() === '') {
      showError('subject', 'subject-error');
      isValid = false;
    } else {
      clearError('subject', 'subject-error');
    }

    // Message
    var body = document.getElementById('body1');
    if (!body || body.value.trim() === '') {
      showError('body1', 'body1-error');
      isValid = false;
    } else {
      clearError('body1', 'body1-error');
    }

    // If valid, submit the form
    if (isValid) {
      document.getElementById('contactID2').submit();
    }
  });

  // Clear errors on input
  ['name1', 'email1', 'date', 'body1'].forEach(function (id) {
    var el = document.getElementById(id);
    if (el) {
      el.addEventListener('input', function () {
        document.getElementById(id + '-error').classList.remove('visible');
        el.classList.remove('input-error');
      });
    }
  });

  document.getElementById('subject').addEventListener('change', function () {
    if (this.value !== 'Select One') {
      document.getElementById('subject-error').classList.remove('visible');
      this.classList.remove('input-error');
    }
  });
</script>

